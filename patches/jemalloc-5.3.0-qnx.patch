 /******************************************************************************/
 
+#ifdef JEMALLOC_OS_QNX
+/*
+ * QNX implementation using posix_memalign
+ * QNX does not support MAP_ANON in the same way as Linux
+ */
+static void *
+os_pages_map(void *addr, size_t size, size_t alignment, bool *commit) {
+	void *ret = NULL;
+	assert(ALIGNMENT_ADDR2BASE(addr, os_page) == addr);
+	assert(ALIGNMENT_CEILING(size, os_page) == size);
+	assert(size != 0);
+
+	/* QNX: use posix_memalign for aligned allocation */
+	if (posix_memalign(&ret, alignment, size) != 0) {
+		return NULL;
+	}
+	*commit = true;
+	return ret;
+}
+
+static void *
+os_pages_trim(void *addr, size_t alloc_size, size_t leadsize, size_t size,
+    bool *commit) {
+	void *ret = (void *)((uintptr_t)addr + leadsize);
+	assert(alloc_size >= leadsize + size);
+	return ret;
+}
+
+static void
+os_pages_unmap(void *addr, size_t size) {
+	assert(ALIGNMENT_ADDR2BASE(addr, os_page) == addr);
+	assert(ALIGNMENT_CEILING(size, os_page) == size);
+
+	free(addr);
+}
+
+#else /* !JEMALLOC_OS_QNX */
+
 static void *
 os_pages_map(void *addr, size_t size, size_t alignment, bool *commit) {
